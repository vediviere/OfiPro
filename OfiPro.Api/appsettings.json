{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=OfiProDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "",
    "Issuer": "OfiPro.Api",
    "Audience": "OfiPro.Client",
    "RefreshTokenExpiresInDays": 30,
